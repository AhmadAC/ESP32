  17   4                                      crc = (crc << 1) ^ CRC_MASK;
  18   4                  }
  19   3                  else {
  20   4                      crc = (crc << 1);
  21   4                  }
  22   3                      }
  23   2              }
  24   1          return crc;
  25   1      }
